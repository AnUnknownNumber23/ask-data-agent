# ask-data-agent — Environment Variables
# Copy this file to .env and fill in your actual API keys
# .env is git-ignored — never commit real keys

# Dev mode: set to true to use built-in mock LLM (no API key needed)
MOCK_LLM=true

# LLM API Keys (only needed when MOCK_LLM is not true)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
QWEN_API_KEY=sk-your-qwen-key-here
GLM_API_KEY=your-glm-key-here

# Database (Docker Compose sets these; change for external services)
PG_PASSWORD=dev-password
